__pycache__/
.pytest_cache/
.ruff_cache/
node_modules/
results/*
!results/.gitkeep
!results/archive/

# E3 raw data (147 MB) is re-fetchable from Zenodo doi:10.5281/zenodo.15359866;
# vendor only the provenance README + fetch script, not the download.
data/e3_new_horizons/*
!data/e3_new_horizons/README.md
!data/e3_new_horizons/fetch_e3_data.py

# E4 raw data (~90 MB of NICER FITS) is re-fetchable from HEASARC; vendor only
# the provenance README + fetch script, not the download. The per-month ObsID
# directories are ignored wholesale (git does not descend into them).
data/e4_nicer/*
!data/e4_nicer/README.md
!data/e4_nicer/fetch_e4_data.py
.planning/

# Timing models (pars/) are COMMITTED, unlike the bulky re-fetchable FITS:
# they are KB-scale text that pins the armor tests' oracle (like golden
# numbers), with provenance + sha256 recorded in data/e4_nicer/README.md.
!data/e4_nicer/pars/
!data/e4_nicer/pars/**

# Astrometry.net 5200 LITE narrow-field index files (~4 GB) are re-downloadable
# from the NERSC mirror; vendor only provenance (see data/README.md), not them.
data/astrometry-index/
data/gaia_dr3_nav_100pc.csv

# Deep-identify Gaia cone cache: per-footprint TAP query results (~1 MB for the
# 12 demo frames), re-fetchable with `python -m gui.prewarm_demo_cones`. Cache,
# not source -- never committed. See data/README.md.
data/gaia_cones/
.playwright-mcp/

# Fresh candidate images for demo pre-testing (re-fetchable; DSS/TESS/HST/NH/photos).
# Cache, not source -- see data/candidates/MANIFEST.md for provenance + fetch URLs.
data/candidates/

# OpenSpace live-marker textures: tiny solid-colour PNGs written at runtime by
# gui/openspace_link.py when pushing markers to a running OpenSpace. Regenerated
# on demand (ensure_marker_textures); cache, not source -- never committed.
.galnav_openspace_runtime/
